#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/config.sh"

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  setup)  source "$SCRIPT_DIR/lib/commands/setup.sh" "$@" ;;
  chat)   source "$SCRIPT_DIR/lib/commands/chat.sh" "$@" ;;
  api)    source "$SCRIPT_DIR/lib/commands/api.sh" "$@" ;;
  stop)   source "$SCRIPT_DIR/lib/commands/stop.sh" "$@" ;;
  aider)  source "$SCRIPT_DIR/lib/commands/aider.sh" "$@" ;;
  ncc)    source "$SCRIPT_DIR/lib/commands/ncc.sh" "$@" ;;
  model)
    echo "Model:       $MODEL"
    echo "Tools model: $TOOLS_MODEL"
    ;;
  help|--help|-h)
    cat <<EOF
free-agent — run AI coding agents locally via Ollama

Usage: ./free-agent <command> [args]

Commands:
  setup           Install Ollama and pull both models
  chat            Interactive chat session
  api "prompt"    Single-prompt API call
  stop            Stop the Ollama server
  aider [setup]   Launch Aider (or run setup first)
  ncc   [setup]   Launch nano-claude-code (or run setup first)
  model           Show the resolved model names

Model:       $MODEL (chat, aider)
Tools model: $TOOLS_MODEL (ncc — tool calling)

Override with FREE_AGENT_MODEL / FREE_AGENT_TOOLS_MODEL env vars
or .model / .tools-model files.
EOF
    ;;
  *)
    echo "Unknown command: $CMD" >&2
    echo "Run './free-agent help' for usage." >&2
    exit 1
    ;;
esac
